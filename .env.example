# URL du cinéma UGC à scraper
UGC_URL=https://www.ugc.fr/cinema-ugc-cine-cite-strasbourg.html

# Identifiants UGC (optionnel, pour accéder aux pages authentifiées)
UGC_EMAIL=votre.email@example.com
UGC_PASSWORD=votre_mot_de_passe

# Cookies personnalisés à injecter en plus, format: nom1=valeur1; nom2=valeur2
UGC_EXTRA_COOKIES=

# URL utilisée pour attacher les cookies personnalisés
UGC_COOKIE_URL=https://www.ugc.fr/

# Niveau de logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Google Calendar
GOOGLE_CALENDAR_SHARED_URL=https://calendar.google.com/calendar/u/0?cid=...
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_PLANNING_ICS=planned_screenings.ics

# Envoi optionnel du fichier ICS par email
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_USE_SSL=true
EMAIL_VERIFY_TLS=true
EMAIL_SMTP_USERNAME=votre.adresse@gmail.com
EMAIL_SMTP_PASSWORD=votre_mot_de_passe_application
EMAIL_FROM=votre.adresse@gmail.com
EMAIL_TO=votre.adresse@gmail.com
EMAIL_SUBJECT=Séances UGC planifiées
EMAIL_BODY=Bonjour,\n\nVoici le fichier ICS des séances UGC planifiées automatiquement.\n

# Planning des séances
UGC_PLANNER_CONFIG=planner_config.json
